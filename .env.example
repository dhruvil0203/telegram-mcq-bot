# Server
PORT=5000

# Ollama — the model used for question generation
OLLAMA_MODEL=qwen2.5:7b

# Telegram (optional — if unset, Telegram sends are skipped)
# Get your token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# For public channels: @your_channel_name
# For private channels: numeric chat ID like -1001234567890
TELEGRAM_CHAT_ID=@your_channel_or_chat_id_here
